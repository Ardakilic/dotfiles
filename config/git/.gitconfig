[user]
    name = Arda Kilicdagi
    email = ardakilicdagi@gmail.com
    # Path to public key; private key (or ssh-agent) signs. Git expands ~ itself.
    signingkey = ~/.ssh/arda.pub

# SSH commit/tag signing (replaces GPG). See ~/.ssh/allowed_signers for trusted keys.
[gpg]
    format = ssh

[gpg "ssh"]
    # Quoted subsection form of gpg.ssh.allowedSignersFile. Git expands ~ itself.
    allowedSignersFile = ~/.ssh/allowed_signers

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[alias]
    # Short log with graph
    lg = log --oneline --graph --decorate
    # Show last commit
    last = log -1 HEAD
    # Show all branches
    branches = branch -a
    # Show all tags
    tags = tag -l
    # Undo last commit (keep changes)
    undo = reset --soft HEAD^1
    # Amend last commit
    amend = commit -a --amend
    # Interactive rebase last n commits
    rebase-last = "!f() { git rebase -i HEAD~$1; }; f"

[core]
    # Global gitignore
    excludesfile = ~/.gitignore_global

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true
    side-by-side = true
    paging = never

[merge]
    conflictStyle = zdiff3

[mergetool "zdiff3"]
    cmd = false
    trustExitCode = true
    keepBackup = false

[init]
    defaultBranch = main

[push]
    default = simple

[pull]
    rebase = true

[fetch]
    prune = true
